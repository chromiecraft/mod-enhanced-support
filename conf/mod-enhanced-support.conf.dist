[worldserver]

########################################
# mod-enhanced-support configuration
########################################
#
#    EnhancedSupport.Enable
#        Description: Master switch for the module.
#        Default:     1 (enabled)
#

EnhancedSupport.Enable = 1

#
#    EnhancedSupport.MailFilter.Action
#        Description: What to do when player-to-player mail's subject or body contains
#                     a configured keyword. Intended to stop gold-seller and scam
#                     advertising. Also gated by EnhancedSupport.Enable. The mail is
#                     always blocked for any value above 0; the action escalates from
#                     there.
#        Default:     0 - Disabled (filter off)
#                     1 - Block mail + notify the sender
#                     2 - Block mail + kick the sender
#                     3 - Block mail + permanently ban the sender's account
#                     4 - Block mail + permanently ban the account and its IP
#

EnhancedSupport.MailFilter.Action = 0

# Keywords are stored in the auth DB table `enhanced_support_mail_keywords`,
# not in this file. Manage them in-game or from the console with:
#   .support keyword add <keyword>
#   .support keyword remove <keyword>
#   .support list keywords
# Matching is case-insensitive and matches anywhere in the mail subject or body.

#
#    EnhancedSupport.MailFilter.Message
#        Description: System chat message shown to the sender when Action = 1 (notify).
#                     Leave empty to send no message (the client still shows a generic
#                     send error). Higher actions kick/ban instead of messaging.
#        Default:     "Your mail was blocked because it contains a prohibited keyword."
#

EnhancedSupport.MailFilter.Message = "Your mail was blocked because it contains a prohibited keyword."

#
#    EnhancedSupport.MailFilter.BanAuthor
#        Description: Author name recorded on bans issued by Action 3/4. Also used as the
#                     default search term for ".enhancedsupport bans" so a bare call lists
#                     the bans this module issued. Avoid setting it to a real character name.
#        Default:     "SupportModule"
#

EnhancedSupport.MailFilter.BanAuthor = "SupportModule"

#
#    EnhancedSupport.MailFilter.SkipSameAccount
#        Description: When enabled, mail sent between two characters on the same account
#                     (i.e. to your own alt) bypasses the mail checks entirely - both the
#                     keyword filter and the high-value (gold) logging. Self-transfers are
#                     never advertising or gold selling, so this removes that noise.
#        Default:     0 - Same-account mail is checked like any other
#                     1 - Skip the mail checks for same-account transfers
#

EnhancedSupport.MailFilter.SkipSameAccount = 0

#
#    EnhancedSupport.ChatFilter.Action
#        Description: What to do when a player's SAY, YELL, EMOTE, PARTY or WHISPER message
#                     contains a configured keyword. Uses the same keyword list as the mail filter
#                     and the same ban author. Also gated by EnhancedSupport.Enable. The
#                     matched message is always suppressed for any value above 0; the
#                     action escalates from there.
#        Default:     0 - Disabled (filter off)
#                     1 - Block message + notify the sender
#                     2 - Block message + kick the sender
#                     3 - Block message + permanently ban the sender's account
#                     4 - Block message + permanently ban the account and its IP
#

EnhancedSupport.ChatFilter.Action = 0

#
#    EnhancedSupport.ChatFilter.Message
#        Description: System chat message shown to the sender when Action = 1 (notify).
#                     Leave empty to send no message. Higher actions kick/ban instead.
#        Default:     "Your message was blocked because it contains a prohibited keyword."
#

EnhancedSupport.ChatFilter.Message = "Your message was blocked because it contains a prohibited keyword."

#
#    EnhancedSupport.AggressiveMaxLevel
#        Description: Catches spam that evades the plain filter by spacing letters out or
#                     swapping in look-alike characters (digits for letters), in both mail
#                     and chat, but only from low-level senders (gold-seller bots are
#                     throwaway low-level characters) whose text also contains a web marker
#                     (.com, www, http, "dot com", ...). Both conditions are required, which
#                     keeps normal phrases like "LFG tank for Onyxia" from matching. Set to
#                     the highest character level this aggressive pass applies to. Matches
#                     reuse each filter's own action (MailFilter.Action / ChatFilter.Action).
#        Default:     0 - Disabled (no aggressive pass; only exact substring matching runs)
#                     e.g. 5 - Apply to characters at or below level 5
#

EnhancedSupport.AggressiveMaxLevel = 0

#
#    EnhancedSupport.ChatFilter.WindowSize
#        Description: Catches advertising split across several chat lines, where each
#                     line is harmless on its own but together they form an ad (a URL
#                     broken up and padded with unrelated chatter). Keeps the
#                     last few SAY/YELL/EMOTE lines per sender and matches the joined
#                     text (with both the strict and the aggressive/collapsed passes).
#                     This is the maximum number of lines kept per sender. The pass only
#                     runs when it is at least 2, WindowSeconds is set, and the sender is
#                     at or below EnhancedSupport.AggressiveMaxLevel (so it inherits the
#                     same low-level + web-marker safeguards and reuses ChatFilter.Action).
#        Default:     0 - Disabled (no cross-message matching)
#                     e.g. 5 - Join up to the sender's last 5 lines
#

EnhancedSupport.ChatFilter.WindowSize = 0

#
#    EnhancedSupport.ChatFilter.WindowSeconds
#        Description: How long (in seconds) a chat line stays in the window above. Lines
#                     older than this are dropped before matching, so only lines sent
#                     close together are joined. Has no effect unless
#                     EnhancedSupport.ChatFilter.WindowSize is at least 2.
#        Default:     0 - Disabled
#                     e.g. 30 - Join lines sent within 30 seconds of each other
#

EnhancedSupport.ChatFilter.WindowSeconds = 0

#
#    EnhancedSupport.InviteFilter.Action
#        Description: What to do when a player fires too many party invites in a short window
#                     (see RateCount / RateSeconds below) - the pattern of throwaway low-level
#                     characters mass-inviting strangers to spam. The offending invite is
#                     always dropped silently for any value above 0 (the spammer sees no error,
#                     the target gets no popup); the action escalates from there. Has its own
#                     action setting, separate from the chat and mail filters. Also gated by
#                     EnhancedSupport.Enable.
#        Default:     0 - Disabled (filter off)
#                     1 - Block invite + notify the sender
#                     2 - Block invite + kick the sender
#                     3 - Block invite + permanently ban the sender's account
#                     4 - Block invite + permanently ban the account and its IP
#

EnhancedSupport.InviteFilter.Action = 0

#
#    EnhancedSupport.InviteFilter.Message
#        Description: System chat message shown to the sender when Action = 1 (notify).
#                     Leave empty to send no message. Higher actions kick/ban instead.
#        Default:     "Your party invite was blocked."
#

EnhancedSupport.InviteFilter.Message = "Your party invite was blocked."

#
#    EnhancedSupport.InviteFilter.RateCount
#    EnhancedSupport.InviteFilter.RateSeconds
#        Description: The rate threshold. An invite is blocked once more than RateCount invites
#                     from the same sender fall within the last RateSeconds. Invites to a
#                     guildmate, to a player who has the inviter on their friends list, or to a
#                     player on the same IP (same household / multiboxer) are never counted.
#                     Both must be > 0 for the filter to run.
#        Default:     0 - Disabled
#                     e.g. RateCount = 3, RateSeconds = 30 - block the 4th invite within 30s
#

EnhancedSupport.InviteFilter.RateCount = 0
EnhancedSupport.InviteFilter.RateSeconds = 0

#
#    EnhancedSupport.InviteFilter.MaxLevel
#        Description: Restrict the invite filter to inviters at or below this level, so it only
#                     watches the low-level throwaway characters spammers use. Has no effect
#                     unless InviteFilter.Action and the rate options above are set.
#        Default:     0 - No cap (watch inviters of any level)
#                     e.g. 5 - Watch only inviters at or below level 5
#

EnhancedSupport.InviteFilter.MaxLevel = 0

#
#    EnhancedSupport.GoldFilter.Threshold
#        Description: Log (and relay to Discord, if mod-chat-transmitter is available) any
#                     player-to-player mail carrying at least this much money. Intended to
#                     surface large transfers for review. Log-only: the mail is never
#                     blocked. Also gated by EnhancedSupport.Enable.
#                     Accepts a gold/silver/copper string like the .send money command,
#                     e.g. "100g", "100g 50s", "250g 30s 10c". A bare number is copper.
#        Default:     "0" - Disabled (no gold check)
#

EnhancedSupport.GoldFilter.Threshold = "0"

#
#    EnhancedSupport.LootFilter.LevelGap
#        Description: Log (and relay to Discord, if mod-chat-transmitter is available) when a
#                     character loots an item whose required level exceeds their own level by
#                     at least this many levels. Intended to surface low-level characters
#                     pulling high-level gear from world chests and similar (boosting/exploits).
#                     Log-only: the loot is never blocked. Also gated by EnhancedSupport.Enable.
#                     Items with no level requirement are ignored.
#        Default:     0 - Disabled (no loot level check)
#

EnhancedSupport.LootFilter.LevelGap = 0

#
#    EnhancedSupport.LootFilter.MaxLevel
#        Description: Restrict the loot level-gap check (above) to looters at or below this
#                     level, so it only watches low-level characters. For example, 10 logs
#                     only characters up to level 10. Has no effect unless
#                     EnhancedSupport.LootFilter.LevelGap is enabled.
#        Default:     0 - No cap (the check applies to looters of any level)
#                     e.g. 10 - Apply only to characters at or below level 10
#

EnhancedSupport.LootFilter.MaxLevel = 0

#
#    EnhancedSupport.LootFilter.BatchSeconds
#        Description: When a looter pulls several flagged items from one container or creature,
#                     coalesce them into a single Discord notification instead of one per item.
#                     The batch is sent once no further item has arrived from that source for
#                     this many seconds (or when the looter loots a different source, or logs
#                     out). Affects the Discord notification only - the server log keeps one
#                     line per item. Requires mod-chat-transmitter.
#        Default:     0 - No batching (one notification per item)
#                     e.g. 3 - Group items looted within 3 seconds of each other
#

EnhancedSupport.LootFilter.BatchSeconds = 0

#
#    EnhancedSupport.AuctionFilter.MaxQuality
#        Description: Log (and relay to Discord, if mod-chat-transmitter is available) auction
#                     house activity involving low-quality items put up for an unreasonable price,
#                     to surface value being moved between characters under the guise of a normal
#                     sale. An auction is flagged when the item's quality is at or below this value
#                     AND its price is at or above AuctionFilter.MinPrice below. Log-only: the
#                     auction is never blocked. Also gated by EnhancedSupport.Enable.
#                     This is the master switch for the auction filter.
#        Default:     -1 - Disabled (no auction check)
#                      0 - Flag grey (poor) items only
#                      1 - Flag grey and white (common) items
#                      2 - Also include green (uncommon) items
#

EnhancedSupport.AuctionFilter.MaxQuality = -1

#
#    EnhancedSupport.AuctionFilter.MinPrice
#        Description: Price at or above which a low-quality auction (see MaxQuality) is flagged.
#                     For example, with MaxQuality = 0 and MinPrice = "1000g", a grey item listed
#                     or sold for 1000g or more is logged. Accepts a gold/silver/copper string
#                     like the .send money command, e.g. "1000g", "500g 50s". A bare number is
#                     copper. Has no effect unless AuctionFilter.MaxQuality is set (>= 0).
#        Default:     "0" - Flag at any price (every low-quality auction)
#

EnhancedSupport.AuctionFilter.MinPrice = "0"

#
#    EnhancedSupport.AuctionFilter.AlwaysLogGrey
#        Description: Log every grey (poor) quality item auction regardless of price, independent
#                     of the MaxQuality / MinPrice settings above. Use this for a blanket audit of
#                     grey-item auctions on top of (or instead of) the price-threshold filter. It
#                     works even when AuctionFilter.MaxQuality is disabled (-1). Respects the
#                     AuctionFilter.OnListing setting below. Log-only; gated by EnhancedSupport.Enable.
#        Default:     0 - Off (grey items follow the MaxQuality / MinPrice rules like any other)
#                     1 - Always log grey-item auctions
#

EnhancedSupport.AuctionFilter.AlwaysLogGrey = 0

#
#    EnhancedSupport.AuctionFilter.GreyMinPrice
#        Description: Grey-specific price threshold: log grey (poor) quality item auctions whose
#                     price is at or above this, independent of the general MaxQuality / MinPrice
#                     settings. Use this to watch grey items at a different (usually lower) price
#                     than other qualities. Works even when AuctionFilter.MaxQuality is disabled
#                     (-1). Has no effect if AuctionFilter.AlwaysLogGrey is on (that already logs
#                     every grey item). Accepts a gold/silver/copper string like the .send money
#                     command, e.g. "1000g", "500g 50s"; a bare number is copper. Respects the
#                     AuctionFilter.OnListing setting. Log-only; gated by EnhancedSupport.Enable.
#        Default:     "0" - Off (grey items follow the MaxQuality / MinPrice rules)
#

EnhancedSupport.AuctionFilter.GreyMinPrice = "0"

#
#    EnhancedSupport.AuctionFilter.OnListing
#        Description: By default only completed sales are flagged (that is where value actually
#                     changes hands, and both seller and buyer are known). Enable this to also
#                     flag the suspicious listing when it is first posted, as an early warning -
#                     at listing time the buyer is not yet known. Has no effect unless the
#                     auction filter is active (any of MaxQuality / AlwaysLogGrey / GreyMinPrice).
#        Default:     0 - Flag completed sales only
#                     1 - Also flag suspicious listings when posted
#

EnhancedSupport.AuctionFilter.OnListing = 0

#
#    EnhancedSupport.AuctionFilter.BatchSeconds
#        Description: When a seller has several flagged auctions in a row (for example, posting
#                     many items at once), coalesce them into a single Discord notification instead
#                     of one per auction. The batch is sent once no further flagged auction has
#                     arrived from that seller for this many seconds. Listings and sales are batched
#                     separately. Affects the Discord notification only - the server log keeps one
#                     line per auction. Requires mod-chat-transmitter.
#        Default:     0 - No batching (one notification per auction)
#                     e.g. 5 - Group auctions flagged within 5 seconds of each other
#

EnhancedSupport.AuctionFilter.BatchSeconds = 0

#
#    EnhancedSupport.EmailFilter.Enable
#        Description: Log (and relay to Discord, if mod-chat-transmitter is available) when a
#                     newly created character belongs to an account whose email contains a
#                     configured substring pattern - surfaces bot/gold-seller accounts that
#                     register with recognizable email patterns. Log-only: character creation is
#                     never blocked. Also gated by EnhancedSupport.Enable. The patterns are not
#                     stored here; manage them in-game or from the console with:
#                       .support emailpattern add <pattern>
#                       .support emailpattern remove <pattern>
#                       .support list emailpatterns
#                     The check only does anything once at least one pattern is configured.
#                     Matching is case-insensitive substring against the account email.
#        Default:     1 - Enabled (runs whenever a pattern is configured)
#                     0 - Disabled (the email check never runs, patterns are kept)
#

EnhancedSupport.EmailFilter.Enable = 1

#
#    EnhancedSupport.StartupNotice.Enable
#        Description: Post a Discord notice when the world server has started, showing the
#                     git revision the server is running. Requires mod-chat-transmitter to
#                     be installed and enabled (it is the transport). Also gated by
#                     EnhancedSupport.Enable.
#        Default:     0 (disabled)
#                     1 (enabled)
#

EnhancedSupport.StartupNotice.Enable = 0

#
#    EnhancedSupport.StartupNotice.Message
#        Description: Headline shown on the startup Discord notice. The revision, branch and
#                     build date are appended automatically.
#        Default:     "Server restarted!"
#

EnhancedSupport.StartupNotice.Message = "Server restarted!"

#
#    EnhancedSupport.StartupNotice.DelaySeconds
#        Description: How long after startup to send the notice. The delay lets the
#                     mod-chat-transmitter WebSocket come up first. Increase it if your
#                     Discord bot connection is slow to establish.
#        Default:     5
#

EnhancedSupport.StartupNotice.DelaySeconds = 5
